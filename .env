# Build- and dev-time configuration. These values are baked into the images and the
# rendered quadlet artifact at build time, so a deployed server needs neither this file
# nor a checkout — only the registry, the secrets and the TLS certificate.
APP_NAME=gefieder
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@nowhere.com
SERVER_NAME=localhost
CRUDMAN_PATH=crudman
GRAFANA_PATH=grafana

# The registry path the custom images live under, ending in the project subfolder, so
# the images are <REGISTRY>/postgresql, <REGISTRY>/crudman and <REGISTRY>/sqlmesh. Set
# it to your namespace on any podman-supported registry, e.g. ghcr.io/your-org/gefieder
# or an Artifactory host such as artifactory.example.com/gefieder. The CI workflow
# pushes the images here and the server's podman-auto-update.timer pulls them from here.
REGISTRY=ghcr.io/your-org/gefieder
IMAGE_TAG=latest

# Development vs. production mode. DEBUG=true serves plain HTTP without certificates and
# shows Django debug pages; the default (false) serves HTTPS only and needs a
# certificate in ~/.config/gefieder/certs/. Changing this requires recreating the
# containers. run-dev.sh sets this to true for the local stack.
DEBUG=false
