{
  "__comment": "Server monitoring dashboard shipped with Gefieder, provisioned from grafana/provisioning/dashboards. It charts the host counters the server-stats collector writes into the ${SERVER_STATS_SCHEMA} schema (see postgresql/initdb/gf_0007_create_server_stats.sh) to help size a future server. The ${APP_NAME}-postgresql datasource uid and the schema name are substituted at build time by grafana/render.sh, so this file is a template: do not load it into Grafana directly.",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  sampled_at AS \"time\",\n  GREATEST(cpu_usage_usec - lag(cpu_usage_usec) OVER (ORDER BY sampled_at), 0)\n    / NULLIF(extract(epoch FROM sampled_at - lag(sampled_at) OVER (ORDER BY sampled_at)) * 1e6, 0) AS \"CPU cores busy\",\n  host_nproc AS \"Host cores\"\nFROM ${SERVER_STATS_SCHEMA}.host_sample\nWHERE $__timeFilter(sampled_at)\nORDER BY sampled_at",
          "refId": "A"
        }
      ],
      "title": "CPU cores used",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  sampled_at AS \"time\",\n  mem_current_bytes AS \"Memory used\",\n  host_mem_total_bytes AS \"Host memory\"\nFROM ${SERVER_STATS_SCHEMA}.host_sample\nWHERE $__timeFilter(sampled_at)\nORDER BY sampled_at",
          "refId": "A"
        }
      ],
      "title": "Memory used",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  sampled_at AS \"time\",\n  GREATEST(io_read_bytes - lag(io_read_bytes) OVER (ORDER BY sampled_at), 0)\n    / NULLIF(extract(epoch FROM sampled_at - lag(sampled_at) OVER (ORDER BY sampled_at)), 0) AS \"Read\",\n  GREATEST(io_write_bytes - lag(io_write_bytes) OVER (ORDER BY sampled_at), 0)\n    / NULLIF(extract(epoch FROM sampled_at - lag(sampled_at) OVER (ORDER BY sampled_at)), 0) AS \"Write\"\nFROM ${SERVER_STATS_SCHEMA}.host_sample\nWHERE $__timeFilter(sampled_at)\nORDER BY sampled_at",
          "refId": "A"
        }
      ],
      "title": "Disk throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${APP_NAME}-postgresql" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  sampled_at AS \"time\",\n  db_size_bytes AS \"Database\",\n  volume_size_bytes AS \"All volumes\",\n  temp_size_bytes AS \"Temp/spill\"\nFROM ${SERVER_STATS_SCHEMA}.host_sample\nWHERE $__timeFilter(sampled_at)\nORDER BY sampled_at",
          "refId": "A"
        }
      ],
      "title": "Storage used",
      "type": "timeseries"
    }
  ],
  "refresh": "",
  "schemaVersion": 39,
  "tags": ["gefieder", "server"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Server monitoring",
  "uid": "gefieder-server-monitoring",
  "version": 1,
  "weekStart": ""
}
