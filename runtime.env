# Runtime configuration. Unlike buildtime.env these values are read when the system runs,
# not when the images are built, so changing one takes effect on the next run without a
# rebuild. The installer places this file at ~/.config/<APP_NAME>/runtime.env.

# How often, in seconds, the server-stats collector samples resource usage. 60s is enough
# to size a server (the values are counter deltas, so a coarser interval loses no total
# volume) while keeping the raw table small over months. The disk-size probes run on a
# slower sub-cadence inside the collector regardless of this value.
SERVER_STATS_INTERVAL=60
