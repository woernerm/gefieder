# Build-time configuration. These values are baked into the images and the
# rendered quadlet artifact at build time.
APP_NAME=gefieder
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@nowhere.com
# Default superuser password used by dev.sh only (install.sh prompts for it instead). It
# is deliberately not "admin", otherwise Grafana shows a "change the default password" 
# prompt on first login. However, the superuser password is controlled by setting a 
# podman secret. Therefore, the password should not be changed in Grafana.
SUPERUSER_DEFAULT_PASSWORD=admin123
SERVER_NAME=localhost
CRUDMAN_PATH=crudman
GRAFANA_PATH=grafana

# The name of the schema that holds the server resource-usage and query statistics.
SERVER_STATS_SCHEMA=server_stats

# The full URL of the GitHub repository from which the installer derives the 
# download URL (e.g. <REPO>/releases/latest/download). Set it to your own repository 
# URL. 
REPO=https://github.com/your-org/gefieder

# Docker image repository URL without https://, http://, or a trailing slash. 
REGISTRY=ghcr.io/your-org/gefieder
IMAGE_TAG=latest

# Proxy settings to use during image builds. Leave empty if you do not build your images
# from behind a proxy. 
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Extra Python package index, e.g. artifactory. Leave empty to use PyPI directly.
PYTHON_INDEX=

# Development vs. production mode. DEBUG=true serves plain HTTP without certificates and
# shows Django debug pages; the default (false) serves HTTPS only and needs a
# certificate in ~/.config/<APP_NAME>/certs/. 
DEBUG=false
