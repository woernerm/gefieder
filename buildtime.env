# Build- and dev-time configuration. These values are baked into the images and the
# rendered quadlet artifact at build time, so a deployed server needs neither this file
# nor a checkout — only the registry, the secrets and the TLS certificate.
APP_NAME=gefieder
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@nowhere.com
SERVER_NAME=localhost
CRUDMAN_PATH=crudman
GRAFANA_PATH=grafana

# The schema that holds the server resource-usage and query statistics used to size a
# future server and to find queries that need an index. It is deliberately NOT called
# "metrics": the whole system reports metrics, so that name would be ambiguous. The value
# is baked into the postgresql image (the init scripts create the schema under this name)
# and read by the collector, so changing it requires a rebuild.
SERVER_STATS_SCHEMA=server_stats

# The path the custom images are named under, ending in the project subfolder, so the
# images are <REGISTRY>/postgresql, <REGISTRY>/crudman and <REGISTRY>/sqlmesh. The CI
# workflow builds and saves the images under this name and the quadlets reference it;
# set it to your namespace, e.g. ghcr.io/your-org/gefieder.
REGISTRY=ghcr.io/your-org/gefieder
IMAGE_TAG=latest

# Company proxy used during image builds, so package installs from public repositories
# (pypi, dockerhub, ...) work from behind a corporate proxy. Leave empty when none is
# needed. The CI workflow reads these and passes them as docker --build-arg values; they
# are consumed only while building and are not baked into the images.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# Development vs. production mode. DEBUG=true serves plain HTTP without certificates and
# shows Django debug pages; the default (false) serves HTTPS only and needs a
# certificate in ~/.config/<APP_NAME>/certs/. This value is rendered into the quadlets at
# build time, so changing it requires rebuilding and re-installing.
DEBUG=false
